  "item": [
    {
      "linkId": "flacc.preamble",
      "type": "display",
      "text": "Observational pain scale for children unable to self-report. Each of 5 categories is scored 0–2; total 0–10. Re-evaluate after analgesia.",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-displayCategory",
          "valueCodeableConcept": {
            "coding": [
              {
                "system": "http://hl7.org/fhir/questionnaire-display-category",
                "code": "instructions"
              }
            ]
          }
        }
      ]
    },
    {
      "linkId": "flacc.face",
      "type": "choice",
      "required": true,
      "prefix": "F.",
      "text": "Face",
      "answerOption": [
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 0
            }
          ],
          "valueCoding": {
            "code": "0",
            "display": "No particular expression or smile"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 1
            }
          ],
          "valueCoding": {
            "code": "1",
            "display": "Occasional grimace or frown, withdrawn, disinterested"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 2
            }
          ],
          "valueCoding": {
            "code": "2",
            "display": "Frequent to constant quivering chin, clenched jaw"
          }
        }
      ]
    },
    {
      "linkId": "flacc.legs",
      "type": "choice",
      "required": true,
      "prefix": "L.",
      "text": "Legs",
      "answerOption": [
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 0
            }
          ],
          "valueCoding": {
            "code": "0",
            "display": "Normal position or relaxed"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 1
            }
          ],
          "valueCoding": {
            "code": "1",
            "display": "Uneasy, restless, tense"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 2
            }
          ],
          "valueCoding": {
            "code": "2",
            "display": "Kicking, or legs drawn up"
          }
        }
      ]
    },
    {
      "linkId": "flacc.activity",
      "type": "choice",
      "required": true,
      "prefix": "A.",
      "text": "Activity",
      "answerOption": [
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 0
            }
          ],
          "valueCoding": {
            "code": "0",
            "display": "Lying quietly, normal position, moves easily"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 1
            }
          ],
          "valueCoding": {
            "code": "1",
            "display": "Squirming, shifting back and forth, tense"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 2
            }
          ],
          "valueCoding": {
            "code": "2",
            "display": "Arched, rigid, or jerking"
          }
        }
      ]
    },
    {
      "linkId": "flacc.cry",
      "type": "choice",
      "required": true,
      "prefix": "C.",
      "text": "Cry",
      "answerOption": [
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 0
            }
          ],
          "valueCoding": {
            "code": "0",
            "display": "No cry (awake or asleep)"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 1
            }
          ],
          "valueCoding": {
            "code": "1",
            "display": "Moans or whimpers, occasional complaint"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 2
            }
          ],
          "valueCoding": {
            "code": "2",
            "display": "Crying steadily, screams or sobs, frequent complaints"
          }
        }
      ]
    },
    {
      "linkId": "flacc.consolability",
      "type": "choice",
      "required": true,
      "prefix": "C.",
      "text": "Consolability",
      "answerOption": [
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 0
            }
          ],
          "valueCoding": {
            "code": "0",
            "display": "Content, relaxed"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 1
            }
          ],
          "valueCoding": {
            "code": "1",
            "display": "Reassured by occasional touching, hugging or being talked to, distractible"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 2
            }
          ],
          "valueCoding": {
            "code": "2",
            "display": "Difficult to console or comfort"
          }
        }
      ]
    },
    {
      "linkId": "flacc.totalScore",
      "type": "integer",
      "text": "FLACC total (0–10): 0 relaxed/comfortable; 1–3 mild discomfort; 4–6 moderate pain; 7–10 severe pain.",
      "readOnly": true,
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
          "valueExpression": {
            "description": "Sum of item ordinalValues",
            "language": "text/fhirpath",
            "expression": "%flaccSum"
          }
        }
      ]
    }
  ]
