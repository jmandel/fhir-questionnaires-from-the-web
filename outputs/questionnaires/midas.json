  "extension": [
    {
      "url": "http://hl7.org/fhir/StructureDefinition/variable",
      "valueExpression": {
        "name": "midasSum",
        "language": "text/fhirpath",
        "expression": "%resource.item.where(linkId in ('midas.q1'|'midas.q2'|'midas.q3'|'midas.q4'|'midas.q5')).answer.valueInteger.sum()"
      }
    }
  ],
  "item": [
    {
      "linkId": "midas.preamble",
      "type": "display",
      "text": "Answer the following questions about ALL of the headaches you have had over the last 3 months. Enter 0 if you did not have the activity in the last 3 months.",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-displayCategory",
          "valueCodeableConcept": {
            "coding": [
              {
                "system": "http://hl7.org/fhir/questionnaire-display-category",
                "code": "instructions"
              }
            ]
          }
        }
      ]
    },
    {
      "linkId": "midas.q1",
      "type": "integer",
      "required": true,
      "prefix": "1.",
      "text": "On how many days in the last 3 months did you miss work or school because of your headaches?",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/minValue",
          "valueInteger": 0
        }
      ]
    },
    {
      "linkId": "midas.q2",
      "type": "integer",
      "required": true,
      "prefix": "2.",
      "text": "How many days in the last 3 months was your productivity at work or school reduced by half or more because of your headaches? (Do not include days you counted in question 1.)",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/minValue",
          "valueInteger": 0
        }
      ]
    },
    {
      "linkId": "midas.q3",
      "type": "integer",
      "required": true,
      "prefix": "3.",
      "text": "On how many days in the last 3 months did you not do household work because of your headaches?",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/minValue",
          "valueInteger": 0
        }
      ]
    },
    {
      "linkId": "midas.q4",
      "type": "integer",
      "required": true,
      "prefix": "4.",
      "text": "How many days in the last 3 months was your productivity in household work reduced by half or more because of your headaches? (Do not include days you counted in question 3.)",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/minValue",
          "valueInteger": 0
        }
      ]
    },
    {
      "linkId": "midas.q5",
      "type": "integer",
      "required": true,
      "prefix": "5.",
      "text": "On how many days in the last 3 months did you miss family, social or leisure activities because of your headaches?",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/minValue",
          "valueInteger": 0
        }
      ]
    },
    {
      "linkId": "midas.totalScore",
      "type": "integer",
      "text": "MIDAS total (sum Q1–Q5)",
      "readOnly": true,
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
          "valueExpression": {
            "description": "Sum of item ordinalValues",
            "language": "text/fhirpath",
            "expression": "%midasSum"
          }
        }
      ]
    },
    {
      "linkId": "midas.qa",
      "type": "integer",
      "required": true,
      "prefix": "A.",
      "text": "On how many days in the last 3 months did you have a headache? (count each day separately)",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/minValue",
          "valueInteger": 0
        }
      ]
    },
    {
      "linkId": "midas.qb",
      "type": "integer",
      "required": true,
      "prefix": "B.",
      "text": "On a scale of 0–10, on average how painful were these headaches? (0 = no pain, 10 = pain as bad as it can be)",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/minValue",
          "valueInteger": 0
        }
      ]
    }
  ]
}
