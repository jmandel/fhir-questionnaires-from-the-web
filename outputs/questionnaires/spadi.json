    {
      "linkId": "spadi.painScore",
      "type": "decimal",
      "readOnly": true,
      "text": "Pain subscale (% of total possible 50; lower is better)",
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
          "valueExpression": {
            "description": "SPADI pain subscale percentage",
            "language": "text/fhirpath",
            "expression": "(%spadiPainSum * 100) / 50"
          }
        }
      ]
    },
    {
      "linkId": "spadi.disabScore",
      "type": "decimal",
      "readOnly": true,
      "text": "Disability subscale (% of total possible 80; lower is better)",
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
          "valueExpression": {
            "description": "SPADI disability subscale percentage",
            "language": "text/fhirpath",
            "expression": "(%spadiDisabSum * 100) / 80"
          }
        }
      ]
    },
    {
      "linkId": "spadi.total",
      "type": "decimal",
      "readOnly": true,
      "text": "SPADI total score (mean of pain and disability subscales)",
      "extension": [
        {
          "url": "http://hl7.org/fhir/uv/sdc/StructureDefinition/sdc-questionnaire-calculatedExpression",
          "valueExpression": {
            "description": "SPADI total percentage",
            "language": "text/fhirpath",
            "expression": "(((%spadiPainSum * 100) / 50) + ((%spadiDisabSum * 100) / 80)) / 2"
          }
        }
      ]
    }
