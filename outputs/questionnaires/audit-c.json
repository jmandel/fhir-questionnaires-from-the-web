            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 1
            }
          ],
          "valueCoding": {
            "system": "http://hobby.intake-forms/fhir/CodeSystem/auditc-q1",
            "code": "monthly-or-less",
            "display": "Monthly or less"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 2
            }
          ],
          "valueCoding": {
            "system": "http://hobby.intake-forms/fhir/CodeSystem/auditc-q1",
            "code": "2-4-per-month",
            "display": "Two to four times a month"
          }
        },
        {
          "extension": [
            {
              "url": "http://hl7.org/fhir/StructureDefinition/ordinalValue",
              "valueDecimal": 3
            }
          ],
          "valueCoding": {
            "system": "http://hobby.intake-forms/fhir/CodeSystem/auditc-q1",
            "code": "2-3-per-week",
