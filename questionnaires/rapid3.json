  "item": [
    {
      "linkId": "rapid3.preamble",
      "type": "display",
      "text": "RAPID3 combines a 10-item physical function scale, a patient pain VAS, and a patient global VAS. Total 0–30 raw or 0–10 normalized. Severity: ≤1 near-remission · 1.01–2 low · 2.01–4 moderate · >4 high.",
      "extension": [
        {
          "url": "http://hl7.org/fhir/StructureDefinition/questionnaire-displayCategory",
          "valueCodeableConcept": {
            "coding": [
              {
                "system": "http://hl7.org/fhir/questionnaire-display-category",
                "code": "instructions"
              }
            ]
          }
        }
      ]
    },
